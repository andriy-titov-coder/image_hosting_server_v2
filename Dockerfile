# """
# Dockerfile для збірки контейнера Python-застосунку.
#
# Він створює мінімальний образ на базі Python 3.12,
# встановлює системні та Python-залежності,
# копіює код застосунку й запускає сервер усередині контейнера.
# """
FROM python:3.12-slim

# """
# На цьому етапі встановлюються системні пакети,
# потрібні для збирання залежностей і роботи з PostgreSQL.
# Після встановлення кеш apt очищається, щоб зменшити розмір образу.
# """
RUN apt-get update && apt-get install -y \
    gcc \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# """
# Створюється окремий користувач appuser,
# від імені якого запускатиметься застосунок у контейнері.
# Це безпечніше, ніж запускати процес від root.
# """
RUN useradd --create-home --shell /bin/bash appuser

# """
# Створюється директорія для завантажених зображень
# і одразу призначається власником користувач appuser.
# """
RUN mkdir -p /images && chown appuser:appuser /images

# """
# Спочатку копіюється файл залежностей і встановлюються Python-пакети.
# Такий порядок допомагає краще використовувати кеш Docker-шарів.
# """
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# """
# Далі в контейнер копіюється вихідний код застосунку.
# """
COPY src/ /app/src/

# """
# Права доступу до каталогу застосунку передаються appuser,
# щоб він міг читати та запускати код без root-привілеїв.
# """
RUN chown -R appuser:appuser /app

# """
# Контейнер переходить на непривілейованого користувача
# і задає робочу директорію застосунку.
# """
USER appuser
WORKDIR /app

# """
# Документується порт, на якому всередині контейнера працює сервер.
# """
EXPOSE 8000

# """
# Команда за замовчуванням запускає Python-сервер застосунку.
# """
CMD ["python", "src/app.py"]
